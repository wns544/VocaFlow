                            <constraint firstItem="IMG-QUIZ-PROGRESS-BAR" firstAttribute="trailing" secondItem="LBL-QUIZ-PROGRESS" secondAttribute="trailing" id="C-QUIZ-PROG-R"/>
                            <constraint firstItem="LBL-QUIZ-PROGRESS" firstAttribute="top" secondItem="IMG-QUIZ-PROGRESS-BAR" secondAttribute="bottom" constant="12" id="C-QUIZ-PROG-T"/>
                            <constraint firstItem="STACK-QUIZ" firstAttribute="leading" secondItem="SAFE-QUIZ" secondAttribute="leading" constant="32" id="C-QUIZ-STACK-L"/>
                            <constraint firstItem="SAFE-QUIZ" firstAttribute="trailing" secondItem="STACK-QUIZ" secondAttribute="trailing" constant="32" id="C-QUIZ-STACK-R"/>
